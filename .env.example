# Copy to .env and adjust for your environment:
#   cp .env.example .env
#
# For Docker Compose, see .env.docker.example (or merge these settings into .env).

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: comma-separated origins for CSRF (required behind HTTPS reverse proxy)
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.example.com

# Optional: SQLite file path (default: db.sqlite3 in project root)
# DATABASE_PATH=/data/db.sqlite3

# ---------------------------------------------------------------------------
# Keycloak OIDC
# ---------------------------------------------------------------------------
# Browser-facing Keycloak URL (used for login/logout redirects)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_PUBLIC_URL=http://localhost:8080

# Server-side Keycloak URL (token, userinfo, JWKS)
# - Local uv dev (same machine): usually same as KEYCLOAK_PUBLIC_URL — leave unset
# - Docker + Keycloak on host: http://host.docker.internal:8080
# - Docker + bundled Keycloak: http://keycloak:8080
# KEYCLOAK_INTERNAL_URL=http://host.docker.internal:8080

KEYCLOAK_REALM=awf
OIDC_RP_CLIENT_ID=awf-web
OIDC_RP_CLIENT_SECRET=your-client-secret-from-keycloak

# ---------------------------------------------------------------------------
# Keycloak groups & admin access
# ---------------------------------------------------------------------------
KEYCLOAK_GROUPS_CLAIM=groups
KEYCLOAK_ADMIN_GROUP=admin
KEYCLOAK_SYNC_DJANGO_GROUPS=true

# ---------------------------------------------------------------------------
# Resource provisioning (My resources)
# ---------------------------------------------------------------------------
# Create only namespace, skip service account / RBAC / token
RESOURCE_PROVISION_NAMESPACE_ONLY=false

# Issue and store personal service account token for workflow submission
RESOURCE_PROVISION_CREATE_USER_TOKEN=true

# Let users view/reveal their token on My resources (admins always see masked token)
RESOURCE_PROVISION_SHOW_USER_TOKEN=false

# Timeout in seconds for Kubernetes API calls during provision/verify/submit
K8S_API_TIMEOUT_SECONDS=30

# ---------------------------------------------------------------------------
# Session / cookies
# ---------------------------------------------------------------------------
# Set to true in production behind HTTPS
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false

# ---------------------------------------------------------------------------
# Docker Compose (optional — see .env.docker.example)
# ---------------------------------------------------------------------------
# Start bundled Keycloak + Postgres with: docker compose --profile keycloak up
# COMPOSE_PROFILES=keycloak

# WEB_PORT=8000
# KEYCLOAK_PORT=8080
# KEYCLOAK_ADMIN=admin
# KEYCLOAK_ADMIN_PASSWORD=admin
