# Docker Compose development settings.
# Copy to .env when running with Docker Compose:
#   cp .env.docker.example .env
#
# ---------------------------------------------------------------------------
# Choose Keycloak mode (pick ONE)
# ---------------------------------------------------------------------------
#
# A) External Keycloak already running on your machine (default)
#    - Leave COMPOSE_PROFILES unset (or comment it out)
#    - Start only the web app:
#        docker compose up --build
#    - Django talks to host Keycloak via host.docker.internal:8080
#
# B) Bundled Keycloak inside Docker Compose
#    - Uncomment the line below:
# COMPOSE_PROFILES=keycloak
#    - Set internal URL to the Compose service name:
# KEYCLOAK_INTERNAL_URL=http://keycloak:8080
#    - Start web + Keycloak + Postgres:
#        docker compose up --build
#    - Or without editing .env:
#        docker compose --profile keycloak up --build
#
# ---------------------------------------------------------------------------

DJANGO_SECRET_KEY=dev-docker-secret-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web

KEYCLOAK_PUBLIC_URL=http://localhost:8080
KEYCLOAK_INTERNAL_URL=http://host.docker.internal:8080
KEYCLOAK_REALM=awf

OIDC_RP_CLIENT_ID=awf-web
OIDC_RP_CLIENT_SECRET=your-client-secret-from-keycloak

KEYCLOAK_GROUPS_CLAIM=groups
KEYCLOAK_ADMIN_GROUP=admin
KEYCLOAK_SYNC_DJANGO_GROUPS=true

SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false

# Allow users to view their personal service account token on My resources
RESOURCE_PROVISION_SHOW_USER_TOKEN=false

# Only used when COMPOSE_PROFILES=keycloak (bundled Keycloak)
# KEYCLOAK_ADMIN=admin
# KEYCLOAK_ADMIN_PASSWORD=admin
# OIDC_RP_CLIENT_SECRET=awf-web-secret
